# Copy this file to .env and fill in your values. .env is gitignored.

# The ALB URL for the deployed llama.cpp server. Get it after deploy with:
#   kubectl get ingress llm-inference -n llm -o jsonpath='{.status.loadBalancer.ingress[0].hostname}'
LLM_ENDPOINT=http://my-alb-123.us-east-1.elb.amazonaws.com

# API key sent to the server. llama-server ignores this, so a dummy is fine.
# Override it only if you put an auth proxy in front of the ALB.
LLM_API_KEY=not-needed
